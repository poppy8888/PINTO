// ══════════════════════════════════════════════════════════════════════════════
// PROVEEDORES
// ══════════════════════════════════════════════════════════════════════════════
function addProv(){
  db.proveedores.push({id:uid(),sem:db.semProv,nombre:"Nuevo proveedor",fecha:"",monto:0,pagado:0,medio:"Pago Fácil",estado:"PENDIENTE"});
  guardar(); renderProv();
}
function delProv(id){ db.proveedores=db.proveedores.filter(p=>p.id!==id); guardar(); renderProv(); }
function toggleProv(id){
  const p=db.proveedores.find(x=>x.id===id);
  if(!p) return;
  if(p.estado==="PAGADO"){ p.estado="PENDIENTE"; p.pagado=0; }
  else { p.estado="PAGADO"; p.pagado=p.monto; }
  guardar(); renderProv();
}
function updateProv(id,field,val){
  const p=db.proveedores.find(x=>x.id===id);
  if(!p) return;
  p[field]=(['monto','pagado'].includes(field))?parseFloat(val)||0:val;
  if(field==='pagado' && p.pagado>=p.monto && p.monto>0){ p.estado="PAGADO"; }
  guardar(); renderProvKPIs();
}

function renderProv(){
  const sem=db.semProv;
  const rows=db.proveedores.filter(p=>p.sem===sem);
  const cont=document.getElementById('prov-rows');
  if(rows.length===0){ cont.innerHTML='<div class="empty-row">No hay proveedores esta semana — agregá uno ↑</div>'; }
  else {
    cont.innerHTML=rows.map(p=>{
      const bc=p.estado==="PAGADO"?"b-pago":p.estado==="VENCIDO"?"b-venc":p.estado==="SIN FECHA"?"b-sf":"b-pend";
      const isPag=p.estado==="PAGADO";
      return `<div class="data-row g-prov ${isPag?'pagado-row':''}">
        <div><input class="cell-input" value="${esc(p.nombre)}" onchange="updateProv('${p.id}','nombre',this.value)" placeholder="Nombre proveedor"></div>
        <div><input class="cell-input" value="${esc(p.fecha)}" onchange="updateProv('${p.id}','fecha',this.value)" placeholder="Fecha / acción"></div>
        <div><input class="cell-input num ${isPag?'paid-style':''}" type="number" value="${p.monto}" onchange="updateProv('${p.id}','monto',this.value)"></div>
        <div><input class="cell-input num ${isPag?'paid-style':''}" type="number" value="${p.pagado}" onchange="updateProv('${p.id}','pagado',this.value)" placeholder="0"></div>
        <div>
          <select class="cell-input" onchange="updateProv('${p.id}','medio',this.value)">
            ${['Pago Fácil','Transferencia','Efectivo','Efectivo → Banco','A definir'].map(m=>`<option ${p.medio===m?'selected':''}>${m}</option>`).join('')}
          </select>
        </div>
        <div style="text-align:center"><span class="badge ${bc}">${p.estado}</span></div>
        <div style="text-align:center"><button class="btn-ok ${isPag?'done':'pend'}" onclick="toggleProv('${p.id}')">${isPag?'↩ Deshacer':'✓ Pagado'}</button></div>
        <div><button class="btn-del" onclick="delProv('${p.id}')" title="Eliminar">✕</button></div>
      </div>`;
    }).join('');
  }
  renderProvKPIs();
}

function renderProvKPIs(){
  let pend=0,pago=0,pf=0,total=0,cpend=0,cpago=0;
  db.proveedores.forEach(p=>{
    total+=p.monto;
    if(p.estado==="PAGADO"){ pago+=p.monto; cpago++; }
    else { pend+=p.monto; cpend++; }
    if(p.medio==="Pago Fácil" && p.estado!=="PAGADO") pf+=p.monto;
  });
  document.getElementById('p-kpi-pend').textContent=fmt(pend);
  document.getElementById('p-kpi-pend-s').textContent=cpend+' proveedores';
  document.getElementById('p-kpi-pago').textContent=fmt(pago);
  document.getElementById('p-kpi-pago-s').textContent=cpago+' pagados ✅';
  document.getElementById('p-kpi-pf').textContent=fmt(pf);
  document.getElementById('p-kpi-total').textContent=fmt(total);
}

// ══════════════════════════════════════════════════════════════════════════════
// GASTOS
// ══════════════════════════════════════════════════════════════════════════════
function addGasto(){
  db.gastos.push({id:uid(),sem:db.semGasto,concepto:"Nuevo gasto",fecha:"",monto:0,pagado:0,medio:"Efectivo",estado:"PENDIENTE"});
  guardar(); renderGastos();
}
function delGasto(id){ db.gastos=db.gastos.filter(g=>g.id!==id); guardar(); renderGastos(); }
function updateGasto(id,field,val){
  const g=db.gastos.find(x=>x.id===id);
  if(!g) return;
  g[field]=(['monto','pagado'].includes(field))?parseFloat(val)||0:val;
  if(field==='pagado' && g.pagado>=g.monto && g.monto>0) g.estado="PAGADO";
  guardar(); renderGastosKPIs();
}
function toggleGasto(id){
  const g=db.gastos.find(x=>x.id===id);
  if(!g) return;
  if(g.estado==="PAGADO"){ g.estado="PENDIENTE"; g.pagado=0; }
  else { g.estado="PAGADO"; g.pagado=g.monto; }
  guardar(); renderGastos();
}

function renderGastos(){
  const sem=db.semGasto;
  const rows=db.gastos.filter(g=>g.sem===sem);
  const cont=document.getElementById('gasto-rows');
  if(rows.length===0){ cont.innerHTML='<div class="empty-row">No hay gastos esta semana — agregá uno ↑</div>'; }
  else {
    cont.innerHTML=rows.map(g=>{
      const bc=g.estado==="PAGADO"?"b-pago":"b-pend";
      const isPag=g.estado==="PAGADO";
      return `<div class="data-row g-gasto ${isPag?'pagado-row':''}">
        <div><input class="cell-input" value="${esc(g.concepto)}" onchange="updateGasto('${g.id}','concepto',this.value)" placeholder="Concepto"></div>
        <div><input class="cell-input" value="${esc(g.fecha)}" onchange="updateGasto('${g.id}','fecha',this.value)" placeholder="Fecha"></div>
        <div><input class="cell-input num ${isPag?'paid-style':''}" type="number" value="${g.monto}" onchange="updateGasto('${g.id}','monto',this.value)"></div>
        <div><input class="cell-input num ${isPag?'paid-style':''}" type="number" value="${g.pagado}" onchange="updateGasto('${g.id}','pagado',this.value)" placeholder="0"></div>
        <div>
          <select class="cell-input" onchange="updateGasto('${g.id}','medio',this.value)">
            ${['Efectivo','Efectivo → Banco','Pago Fácil','Transferencia'].map(m=>`<option ${g.medio===m?'selected':''}>${m}</option>`).join('')}
          </select>
        </div>
        <div style="text-align:center"><button class="btn-ok ${isPag?'done':'pend'}" onclick="toggleGasto('${g.id}')">${isPag?'↩ Deshacer':'✓ Pagado'}</button></div>
        <div><button class="btn-del" onclick="delGasto('${g.id}')" title="Eliminar">✕</button></div>
      </div>`;
    }).join('');
  }
  renderGastosKPIs();
}

function renderGastosKPIs(){
  let pend=0,pago=0,total=0;
  db.gastos.forEach(g=>{ total+=g.monto; if(g.estado==="PAGADO") pago+=g.monto; else pend+=g.monto; });
  document.getElementById('g-kpi-pend').textContent=fmt(pend);
  document.getElementById('g-kpi-pago').textContent=fmt(pago);
  document.getElementById('g-kpi-total').textContent=fmt(total);
}

// ══════════════════════════════════════════════════════════════════════════════
// RECAUDACIÓN
// ══════════════════════════════════════════════════════════════════════════════
const META_LUN=373000;
function addRecaud(){
  db.recaudacion.push({id:uid(),sem:db.semRecaud,dia:"",efectivo:0,transferencia:0});
  guardar(); renderRecaud();
}
function delRecaud(id){ db.recaudacion=db.recaudacion.filter(r=>r.id!==id); guardar(); renderRecaud(); }
function updateRecaud(id,field,val){
  const r=db.recaudacion.find(x=>x.id===id);
  if(!r) return;
  r[field]=(['efectivo','transferencia'].includes(field))?parseFloat(val)||0:val;
  guardar(); renderRecaudKPIs();
}

function renderRecaud(){
  const sem=db.semRecaud;
  const rows=db.recaudacion.filter(r=>r.sem===sem);
  const cont=document.getElementById('recaud-rows');
  if(rows.length===0){ cont.innerHTML='<div class="empty-row">No hay días cargados — agregá uno ↑</div>'; }
  else {
    cont.innerHTML=rows.map(r=>{
      const tot=(r.efectivo||0)+(r.transferencia||0);
      return `<div class="data-row g-recaud">
        <div><input class="cell-input" value="${esc(r.dia)}" onchange="updateRecaud('${r.id}','dia',this.value)" placeholder="Ej: Lunes 16/03"></div>
        <div><input class="cell-input num" type="number" value="${r.efectivo||''}" onchange="updateRecaud('${r.id}','efectivo',this.value)" placeholder="0"></div>
        <div><input class="cell-input num" type="number" value="${r.transferencia||''}" onchange="updateRecaud('${r.id}','transferencia',this.value)" placeholder="0"></div>
        <div style="font-family:'Syne',sans-serif;font-weight:700;text-align:right;padding-right:8px;color:${tot>0?'var(--green)':'var(--muted)'}">${tot>0?fmt(tot):'-'}</div>
        <div><button class="btn-del" onclick="delRecaud('${r.id}')" title="Eliminar">✕</button></div>
      </div>`;
    }).join('');
  }
  renderRecaudKPIs();
}

function renderRecaudKPIs(){
  const sem1=db.recaudacion.filter(r=>r.sem===1);
  const semAct=db.recaudacion.filter(r=>r.sem===db.semRecaud);
  const todas=db.recaudacion;
  const totSem1=sem1.reduce((a,r)=>a+(r.efectivo||0)+(r.transferencia||0),0);
  const totSemAct=semAct.reduce((a,r)=>a+(r.efectivo||0)+(r.transferencia||0),0);
  const totMes=todas.reduce((a,r)=>a+(r.efectivo||0)+(r.transferencia||0),0);

  // hoy = viernes 13 (último cargado de sem 1)
  const hoyRow=db.recaudacion.filter(r=>r.dia&&r.dia.toLowerCase().includes('13'));
  const hoy=hoyRow.length>0?(hoyRow[0].efectivo||0)+(hoyRow[0].transferencia||0):0;

  document.getElementById('r-kpi-hoy').textContent=fmt(hoy);
  document.getElementById('r-kpi-sem').textContent=fmt(totSemAct);
  document.getElementById('r-kpi-mes').textContent=fmt(totMes);

  // Barra meta (solo sem 1)
  const pct=Math.min(totSem1/META_LUN*100,100);
  const falta=Math.max(META_LUN-totSem1,0);
  document.getElementById('meta-recaud').textContent=fmt(totSem1);
  document.getElementById('meta-falta').textContent=falta>0?fmt(falta):'✅ Meta superada';
  document.getElementById('r-kpi-meta-s').textContent=falta>0?'falta '+fmt(falta):'¡Meta alcanzada!';
  const barra=document.getElementById('meta-barra');
  barra.style.width=pct+'%';
  barra.style.background=pct>=100?'linear-gradient(90deg,var(--green),#34d399)':pct>=75?'linear-gradient(90deg,var(--accent),var(--green))':'linear-gradient(90deg,var(--amber),var(--red))';
  const est=document.getElementById('meta-estado');
  if(totSem1>=META_LUN){ est.className='estado-box e-ok'; est.textContent='✅ ¡Llegás sola! Recaudaste '+fmt(totSem1)+' — suficiente para el depósito del lunes.'; }
  else if(totSem1>=META_LUN*0.75){ est.className='estado-box e-warn'; est.textContent='⚠️ Falta '+fmt(falta)+'. Puede que necesites el swap por la diferencia.'; }
  else { est.className='estado-box e-swap'; est.textContent='🔄 Falta '+fmt(falta)+'. Preparar el swap — llamá al conocido la noche del domingo.'; }
}

// ══════════════════════════════════════════════════════════════════════════════
// RENDICIÓN PF
// ══════════════════════════════════════════════════════════════════════════════
function addPF(){
  db.rendicionPF.push({id:uid(),concepto:"Nuevo",fechaUso:"",usado:0,fechaRep:"",repuesto:0,estado:"PENDIENTE"});
  guardar(); renderPF();
}
function delPF(id){ db.rendicionPF=db.rendicionPF.filter(p=>p.id!==id); guardar(); renderPF(); }
function updatePF(id,field,val){
  const p=db.rendicionPF.find(x=>x.id===id);
  if(!p) return;
  p[field]=(['usado','repuesto'].includes(field))?parseFloat(val)||0:val;
  if(p.repuesto>=p.usado && p.usado>0) p.estado="REPUESTO";
  else if(p.repuesto>0) p.estado="PARCIAL";
  else p.estado="PENDIENTE";
  guardar(); renderPFKPIs();
}

function renderPF(){
  const cont=document.getElementById('pf-rows');
  if(db.rendicionPF.length===0){ cont.innerHTML='<div class="empty-row">No hay movimientos — agregá uno ↑</div>'; return; }
  cont.innerHTML=db.rendicionPF.map(p=>{
    const bc=p.estado==="REPUESTO"?"b-pago":p.estado==="PARCIAL"?"b-pend":"b-venc";
    const dif=p.repuesto-p.usado;
    return `<div class="data-row g-pf">
      <div><input class="cell-input" value="${esc(p.concepto)}" onchange="updatePF('${p.id}','concepto',this.value)"></div>
      <div><input class="cell-input" value="${esc(p.fechaUso)}" onchange="updatePF('${p.id}','fechaUso',this.value)" placeholder="dd/mm"></div>
      <div><input class="cell-input num" type="number" value="${p.usado}" onchange="updatePF('${p.id}','usado',this.value)"></div>
      <div><input class="cell-input" value="${esc(p.fechaRep)}" onchange="updatePF('${p.id}','fechaRep',this.value)" placeholder="dd/mm"></div>
      <div><input class="cell-input num ${p.estado==='REPUESTO'?'paid-style':''}" type="number" value="${p.repuesto}" onchange="updatePF('${p.id}','repuesto',this.value)" placeholder="0"></div>
      <div style="text-align:center"><span class="badge ${bc}">${p.estado}</span></div>
      <div><button class="btn-del" onclick="delPF('${p.id}')" title="Eliminar">✕</button></div>
    </div>`;
  }).join('');
  renderPFKPIs();
}

function renderPFKPIs(){
  let usado=0,repuesto=0;
  db.rendicionPF.forEach(p=>{ usado+=p.usado; repuesto+=p.repuesto; });
  const dif=usado-repuesto;
  document.getElementById('pf-kpi-usado').textContent=fmt(usado);
  document.getElementById('pf-kpi-repuesto').textContent=fmt(repuesto);
  const difEl=document.getElementById('pf-kpi-dif');
  difEl.textContent=fmt(dif);
  difEl.className='kpi-v '+(dif>0?'red':'green');
}

// ══════════════════════════════════════════════════════════════════════════════
// RESUMEN MES
// ══════════════════════════════════════════════════════════════════════════════
function renderResumen(){
  const totProvPend=db.proveedores.filter(p=>p.estado!=="PAGADO").reduce((a,p)=>a+p.monto,0);
  const totProvPago=db.proveedores.filter(p=>p.estado==="PAGADO").reduce((a,p)=>a+p.monto,0);
  const totGastoPend=db.gastos.filter(g=>g.estado!=="PAGADO").reduce((a,g)=>a+g.monto,0);
  const totGastoPago=db.gastos.filter(g=>g.estado==="PAGADO").reduce((a,g)=>a+g.monto,0);
  const totRecaud=db.recaudacion.reduce((a,r)=>a+(r.efectivo||0)+(r.transferencia||0),0);
  const totPFUsado=db.rendicionPF.reduce((a,p)=>a+p.usado,0);
  const totPFRep=db.rendicionPF.reduce((a,p)=>a+p.repuesto,0);
  const totalEgresos=totProvPend+totProvPago+totGastoPend+totGastoPago;
  const balance=totRecaud-totalEgresos;

  // Por semana
  const semResumen=[1,2,3,4].map(s=>{
    const pp=db.proveedores.filter(x=>x.sem===s).reduce((a,x)=>a+x.monto,0);
    const gg=db.gastos.filter(x=>x.sem===s).reduce((a,x)=>a+x.monto,0);
    const rr=db.recaudacion.filter(x=>x.sem===s).reduce((a,x)=>a+(x.efectivo||0)+(x.transferencia||0),0);
    return {sem:s,prov:pp,gastos:gg,recaud:rr};
  });

  document.getElementById('resumen-content').innerHTML=`
  <div class="kpi-strip" style="margin-bottom:24px;">
    <div class="kpi"><span class="kpi-l">Total recaudado</span><span class="kpi-v green">${fmt(totRecaud)}</span><span class="kpi-s">ventas del mes</span></div>
    <div class="kpi"><span class="kpi-l">Prov. pendientes</span><span class="kpi-v red">${fmt(totProvPend)}</span><span class="kpi-s">por pagar</span></div>
    <div class="kpi"><span class="kpi-l">Prov. pagados</span><span class="kpi-v green">${fmt(totProvPago)}</span><span class="kpi-s">este mes</span></div>
    <div class="kpi"><span class="kpi-l">Gastos</span><span class="kpi-v amber">${fmt(totGastoPend+totGastoPago)}</span><span class="kpi-s">total mes</span></div>
    <div class="kpi"><span class="kpi-l">PF sin reponer</span><span class="kpi-v ${totPFUsado-totPFRep>0?'red':'green'}">${fmt(totPFUsado-totPFRep)}</span><span class="kpi-s">debe a la empresa</span></div>
  </div>
  <div class="mes-grid">
    ${semResumen.map(s=>`
    <div class="mes-card">
      <div class="mes-card-title">Semana ${s.sem} · ${semLabels[s.sem-1]}</div>
      <div class="mes-row"><span>Proveedores</span><span style="color:var(--red)">${fmt(s.prov)}</span></div>
      <div class="mes-row"><span>Gastos varios</span><span style="color:var(--amber)">${fmt(s.gastos)}</span></div>
      <div class="mes-row"><span>Recaudación</span><span style="color:var(--green)">${fmt(s.recaud)}</span></div>
      <div class="mes-row"><span>Balance sem.</span><span style="color:${s.recaud-(s.prov+s.gastos)>=0?'var(--green)':'var(--red)'}">${fmt(s.recaud-s.prov-s.gastos)}</span></div>
    </div>`).join('')}
    <div class="mes-card" style="border-color:var(--accent)">
      <div class="mes-card-title" style="color:var(--accent)">📊 Total Mes</div>
      <div class="mes-row"><span>Total proveedores</span><span style="color:var(--red)">${fmt(totProvPend+totProvPago)}</span></div>
      <div class="mes-row"><span>Total gastos</span><span style="color:var(--amber)">${fmt(totGastoPend+totGastoPago)}</span></div>
      <div class="mes-row"><span>Total recaudado</span><span style="color:var(--green)">${fmt(totRecaud)}</span></div>
      <div class="mes-row"><span>PF por reponer</span><span style="color:${totPFUsado-totPFRep>0?'var(--red)':'var(--green)'}">${fmt(totPFUsado-totPFRep)}</span></div>
      <div class="mes-row" style="margin-top:4px;padding-top:8px;border-top:1px solid var(--border)"><span>Balance mes</span><span style="color:${balance>=0?'var(--green)':'var(--red)';font-size:15px">${fmt(balance)}</span></div>
    </div>
  </div>`;
}

// ── UTILS ─────────────────────────────────────────────────────────────────────
function esc(s){ return (s||'').replace(/"/g,'&quot;'); }

// ── INIT ──────────────────────────────────────────────────────────────────────
cargar();
renderProv();
renderGastos();
renderRecaud();
renderPF();
</script>
