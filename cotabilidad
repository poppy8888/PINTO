<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Contabilidad — Negocio Ganem</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{--bg:#0b0f1a;--surface:#131929;--card:#1a2235;--border:#243050;--accent:#3b82f6;--green:#10b981;--amber:#f59e0b;--red:#ef4444;--indigo:#6366f1;--pink:#ec4899;--text:#e8edf8;--muted:#6b7a99;}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;min-height:100vh;}
/* HEADER */
header{background:linear-gradient(135deg,#0f1e3d,#0b0f1a);border-bottom:1px solid var(--border);padding:18px 28px;display:flex;align-items:center;gap:14px;position:sticky;top:0;z-index:100;}
.h-logo{width:38px;height:38px;background:var(--accent);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;box-shadow:0 0 16px rgba(59,130,246,.4);}
.h-title{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(14px,2vw,19px);letter-spacing:-.3px;}
.h-sub{font-size:11px;color:var(--muted);margin-top:1px;}
.h-right{margin-left:auto;display:flex;align-items:center;gap:10px;}
.h-badge{background:rgba(59,130,246,.12);border:1px solid rgba(59,130,246,.3);border-radius:20px;padding:4px 12px;font-size:11px;color:var(--accent);font-weight:600;}
.h-save{font-size:11px;color:var(--green);opacity:0;transition:opacity .5s;}
.h-save.show{opacity:1;}
/* TABS */
.tabs{display:flex;gap:0;border-bottom:1px solid var(--border);background:var(--surface);padding:0 28px;overflow-x:auto;}
.tab{padding:14px 20px;font-size:13px;font-weight:600;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;transition:all .2s;}
.tab:hover{color:var(--text);}
.tab.active{color:var(--accent);border-bottom-color:var(--accent);}
/* PANEL */
.panel{display:none;padding:24px 28px;}
.panel.active{display:block;}
/* KPI STRIP */
.kpi-strip{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:1px;background:var(--border);border-radius:12px;overflow:hidden;margin-bottom:24px;}
.kpi{background:var(--card);padding:16px 18px;display:flex;flex-direction:column;gap:2px;}
.kpi-l{font-size:10px;text-transform:uppercase;letter-spacing:1px;color:var(--muted);font-weight:500;}
.kpi-v{font-family:'Syne',sans-serif;font-weight:700;font-size:clamp(15px,2vw,20px);letter-spacing:-.3px;}
.kpi-v.red{color:var(--red)}.kpi-v.green{color:var(--green)}.kpi-v.blue{color:var(--accent)}.kpi-v.amber{color:var(--amber)}
.kpi-s{font-size:10px;color:var(--muted);}
/* SEMANA SELECTOR */
.semana-nav{display:flex;align-items:center;gap:12px;margin-bottom:20px;}
.sem-btn{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:7px 14px;color:var(--text);font-size:13px;font-weight:600;cursor:pointer;transition:all .2s;}
.sem-btn:hover{border-color:var(--accent);color:var(--accent);}
.sem-btn.active{background:var(--accent);border-color:var(--accent);color:#fff;}
.sem-label{font-family:'Syne',sans-serif;font-weight:700;font-size:15px;}
/* TABLA GENERAL */
.card-box{background:var(--card);border:1px solid var(--border);border-radius:14px;overflow:hidden;margin-bottom:20px;}
.card-head{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--border);}
.card-head-title{font-family:'Syne',sans-serif;font-weight:700;font-size:14px;}
.add-btn{background:rgba(59,130,246,.15);border:1px solid rgba(59,130,246,.25);border-radius:8px;padding:6px 14px;color:#60a5fa;font-size:12px;font-weight:600;cursor:pointer;transition:all .2s;}
.add-btn:hover{background:rgba(59,130,246,.3);}
.add-btn.green{background:rgba(16,185,129,.15);border-color:rgba(16,185,129,.25);color:#34d399;}
.add-btn.green:hover{background:rgba(16,185,129,.3);}
/* ROWS */
.row-header{display:grid;padding:8px 16px;background:var(--surface);border-bottom:1px solid var(--border);}
.col-label{font-size:10px;text-transform:uppercase;letter-spacing:1px;color:var(--muted);font-weight:600;}
.data-row{display:grid;padding:10px 16px;border-bottom:1px solid rgba(36,48,80,.5);align-items:center;transition:background .15s;}
.data-row:last-child{border-bottom:none;}
.data-row:hover{background:rgba(255,255,255,.02);}
.data-row.pagado-row{opacity:.55;}
/* INPUTS */
.cell-input{background:transparent;border:1px solid transparent;border-radius:6px;padding:5px 7px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:12px;width:100%;outline:none;transition:all .2s;}
.cell-input:hover{border-color:var(--border);background:var(--surface);}
.cell-input:focus{border-color:var(--accent);background:var(--surface);}
.cell-input.num{font-family:'Syne',sans-serif;font-weight:700;text-align:right;}
.cell-input.paid-style{color:var(--green);}
select.cell-input option{background:var(--card);}
/* BADGES */
.badge{font-size:10px;font-weight:700;padding:3px 9px;border-radius:20px;text-align:center;white-space:nowrap;}
.b-pend{background:rgba(245,158,11,.15);color:#fbbf24;border:1px solid rgba(245,158,11,.2);}
.b-pago{background:rgba(16,185,129,.15);color:#34d399;border:1px solid rgba(16,185,129,.2);}
.b-venc{background:rgba(239,68,68,.15);color:#f87171;border:1px solid rgba(239,68,68,.2);}
.b-sf  {background:rgba(107,122,153,.15);color:var(--muted);border:1px solid rgba(107,122,153,.2);}
/* BOTONES ACCION */
.btn-ok{font-size:11px;font-weight:700;padding:5px 11px;border-radius:7px;border:none;cursor:pointer;transition:all .2s;white-space:nowrap;}
.btn-ok.pend{background:rgba(59,130,246,.15);color:#60a5fa;border:1px solid rgba(59,130,246,.25);}
.btn-ok.pend:hover{background:rgba(59,130,246,.3);}
.btn-ok.done{background:rgba(239,68,68,.1);color:#f87171;border:1px solid rgba(239,68,68,.2);}
.btn-ok.done:hover{background:rgba(239,68,68,.25);}
.btn-del{background:none;border:none;color:var(--muted);cursor:pointer;font-size:14px;padding:4px 6px;border-radius:5px;transition:all .2s;}
.btn-del:hover{color:var(--red);background:rgba(239,68,68,.1);}
/* GRID COLS */
.g-prov{grid-template-columns:2fr 1.4fr 1.1fr 1.1fr 1fr 100px 80px 32px;}
.g-gasto{grid-template-columns:2fr 1.2fr 1.1fr 1.1fr 1fr 80px 32px;}
.g-recaud{grid-template-columns:1fr 1fr 1fr 1fr 80px;}
.g-pf{grid-template-columns:1.5fr 1fr 1fr 1fr 1fr 80px;}
/* BARRA META */
.meta-box{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:20px;margin-bottom:20px;}
.meta-title{font-family:'Syne',sans-serif;font-weight:700;font-size:14px;margin-bottom:12px;}
.barra-outer{height:12px;background:var(--border);border-radius:6px;overflow:hidden;margin:8px 0;}
.barra-inner{height:100%;border-radius:6px;transition:width .5s;}
.meta-row{display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px;}
.estado-box{border-radius:9px;padding:10px 14px;font-size:12px;font-weight:500;line-height:1.5;margin-top:10px;}
.e-ok{background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.25);color:#34d399;}
.e-warn{background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.25);color:#fbbf24;}
.e-swap{background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.25);color:#f87171;}
/* RESUMEN MENSUAL */
.mes-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px;}
.mes-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:16px;}
.mes-card-title{font-family:'Syne',sans-serif;font-weight:700;font-size:13px;margin-bottom:12px;color:var(--accent);}
.mes-row{display:flex;justify-content:space-between;font-size:12px;padding:5px 0;border-bottom:1px solid rgba(36,48,80,.4);}
.mes-row:last-child{border-bottom:none;font-weight:700;}
.mes-row span:last-child{font-family:'Syne',sans-serif;font-weight:700;}
/* EMPTY */
.empty-row{padding:20px;text-align:center;color:var(--muted);font-size:13px;font-style:italic;}
/* RESPONSIVE */
@media(max-width:800px){
  .panel{padding:16px;}
  .g-prov{grid-template-columns:2fr 1fr 1fr 70px 28px;}
  .g-prov .col-3,.g-prov .col-4,.g-prov .col-5{display:none;}
  header,.tabs{padding-left:14px;padding-right:14px;}
  .h-badge{display:none;}
}
</style>
</head>
<body>

<header>
  <div class="h-logo">💼</div>
  <div>
    <div class="h-title">Contabilidad — Negocio Ganem</div>
    <div class="h-sub">Pinto, Santiago del Estero · <span id="mes-actual">Marzo 2026</span></div>
  </div>
  <div class="h-right">
    <span class="h-save" id="save-indicator">✓ Guardado</span>
    <div class="h-badge">🔒 Uso interno</div>
  </div>
</header>

<div class="tabs">
  <div class="tab active" onclick="showTab('proveedores')">📋 Proveedores</div>
  <div class="tab" onclick="showTab('gastos')">💡 Gastos Varios</div>
  <div class="tab" onclick="showTab('recaudacion')">💰 Recaudación</div>
  <div class="tab" onclick="showTab('rendicion')">🔄 Rendición PF</div>
  <div class="tab" onclick="showTab('resumen')">📊 Resumen Mes</div>
</div>

<!-- ═══ PANEL PROVEEDORES ═══════════════════════════════════════════════════ -->
<div class="panel active" id="panel-proveedores">
  <div class="kpi-strip">
    <div class="kpi"><span class="kpi-l">Pendiente</span><span class="kpi-v red" id="p-kpi-pend">-</span><span class="kpi-s" id="p-kpi-pend-s">-</span></div>
    <div class="kpi"><span class="kpi-l">Pagado</span><span class="kpi-v green" id="p-kpi-pago">-</span><span class="kpi-s" id="p-kpi-pago-s">-</span></div>
    <div class="kpi"><span class="kpi-l">Pago Fácil por reponer</span><span class="kpi-v blue" id="p-kpi-pf">-</span><span class="kpi-s">usado no repuesto</span></div>
    <div class="kpi"><span class="kpi-l">Total mes</span><span class="kpi-v amber" id="p-kpi-total">-</span><span class="kpi-s">todos los proveedores</span></div>
  </div>

  <div class="semana-nav">
    <span class="sem-label">Semana:</span>
    <button class="sem-btn active" onclick="setSemProv(1)">Sem 1</button>
    <button class="sem-btn" onclick="setSemProv(2)">Sem 2</button>
    <button class="sem-btn" onclick="setSemProv(3)">Sem 3</button>
    <button class="sem-btn" onclick="setSemProv(4)">Sem 4</button>
    <span style="font-size:12px;color:var(--muted);margin-left:8px;" id="sem-prov-label">13–21 mar</span>
  </div>

  <div class="card-box">
    <div class="card-head">
      <span class="card-head-title">Pagos a proveedores</span>
      <button class="add-btn" onclick="addProv()">+ Agregar proveedor</button>
    </div>
    <div class="row-header g-prov">
      <div class="col-label">Proveedor</div>
      <div class="col-label col-3">Fecha / Acción</div>
      <div class="col-label" style="text-align:right">Monto ($)</div>
      <div class="col-label col-4" style="text-align:right">Pagado ($)</div>
      <div class="col-label col-5">Medio</div>
      <div class="col-label" style="text-align:center">Estado</div>
      <div class="col-label" style="text-align:center">Acción</div>
      <div></div>
    </div>
    <div id="prov-rows"></div>
  </div>
</div>

<!-- ═══ PANEL GASTOS ════════════════════════════════════════════════════════ -->
<div class="panel" id="panel-gastos">
  <div class="kpi-strip">
    <div class="kpi"><span class="kpi-l">Gastos pendientes</span><span class="kpi-v red" id="g-kpi-pend">-</span><span class="kpi-s">por pagar/rendir</span></div>
    <div class="kpi"><span class="kpi-l">Gastos pagados</span><span class="kpi-v green" id="g-kpi-pago">-</span><span class="kpi-s">este mes</span></div>
    <div class="kpi"><span class="kpi-l">Total gastos mes</span><span class="kpi-v amber" id="g-kpi-total">-</span><span class="kpi-s">todos</span></div>
  </div>

  <div class="semana-nav">
    <span class="sem-label">Semana:</span>
    <button class="sem-btn active" onclick="setSemGasto(1)">Sem 1</button>
    <button class="sem-btn" onclick="setSemGasto(2)">Sem 2</button>
    <button class="sem-btn" onclick="setSemGasto(3)">Sem 3</button>
    <button class="sem-btn" onclick="setSemGasto(4)">Sem 4</button>
    <span style="font-size:12px;color:var(--muted);margin-left:8px;" id="sem-gasto-label">13–21 mar</span>
  </div>

  <div class="card-box">
    <div class="card-head">
      <span class="card-head-title">Gastos varios</span>
      <button class="add-btn" onclick="addGasto()">+ Agregar gasto</button>
    </div>
    <div class="row-header g-gasto">
      <div class="col-label">Concepto</div>
      <div class="col-label">Fecha</div>
      <div class="col-label" style="text-align:right">Monto ($)</div>
      <div class="col-label" style="text-align:right">Pagado ($)</div>
      <div class="col-label">Medio</div>
      <div class="col-label" style="text-align:center">Estado</div>
      <div></div>
    </div>
    <div id="gasto-rows"></div>
  </div>
</div>

<!-- ═══ PANEL RECAUDACIÓN ═══════════════════════════════════════════════════ -->
<div class="panel" id="panel-recaudacion">
  <div class="kpi-strip">
    <div class="kpi"><span class="kpi-l">Recaudado hoy</span><span class="kpi-v green" id="r-kpi-hoy">-</span><span class="kpi-s">día actual</span></div>
    <div class="kpi"><span class="kpi-l">Esta semana</span><span class="kpi-v blue" id="r-kpi-sem">-</span><span class="kpi-s">semana seleccionada</span></div>
    <div class="kpi"><span class="kpi-l">Total mes</span><span class="kpi-v amber" id="r-kpi-mes">-</span><span class="kpi-s">acumulado</span></div>
    <div class="kpi"><span class="kpi-l">Meta depósito lunes</span><span class="kpi-v" id="r-kpi-meta" style="color:var(--amber)">$373.000</span><span class="kpi-s" id="r-kpi-meta-s">-</span></div>
  </div>

  <!-- Barra meta -->
  <div class="meta-box">
    <div class="meta-title">💰 Meta recaudación fin de semana → depósito lunes $373.000</div>
    <div class="meta-row"><span style="color:var(--muted)">Recaudado:</span><span id="meta-recaud" style="font-family:'Syne',sans-serif;font-weight:700">$0</span></div>
    <div class="meta-row"><span style="color:var(--muted)">Falta:</span><span id="meta-falta" style="font-family:'Syne',sans-serif;font-weight:700;color:var(--amber)">$373.000</span></div>
    <div class="barra-outer"><div class="barra-inner" id="meta-barra" style="width:0%;background:var(--amber)"></div></div>
    <div class="estado-box e-swap" id="meta-estado">🔄 Cargá los días del fin de semana para ver si llegás sola o necesitás el swap.</div>
  </div>

  <div class="semana-nav">
    <span class="sem-label">Semana:</span>
    <button class="sem-btn active" onclick="setSemRecaud(1)">Sem 1</button>
    <button class="sem-btn" onclick="setSemRecaud(2)">Sem 2</button>
    <button class="sem-btn" onclick="setSemRecaud(3)">Sem 3</button>
    <button class="sem-btn" onclick="setSemRecaud(4)">Sem 4</button>
  </div>

  <div class="card-box">
    <div class="card-head">
      <span class="card-head-title">Recaudación diaria</span>
      <button class="add-btn green" onclick="addRecaud()">+ Agregar día</button>
    </div>
    <div class="row-header g-recaud">
      <div class="col-label">Día / Fecha</div>
      <div class="col-label" style="text-align:right">Efectivo ($)</div>
      <div class="col-label" style="text-align:right">Transferencia ($)</div>
      <div class="col-label" style="text-align:right">Total día ($)</div>
      <div></div>
    </div>
    <div id="recaud-rows"></div>
  </div>
</div>

<!-- ═══ PANEL RENDICIÓN PF ══════════════════════════════════════════════════ -->
<div class="panel" id="panel-rendicion">
  <div class="kpi-strip">
    <div class="kpi"><span class="kpi-l">Total usado PF</span><span class="kpi-v blue" id="pf-kpi-usado">-</span><span class="kpi-s">de la empresa</span></div>
    <div class="kpi"><span class="kpi-l">Total repuesto</span><span class="kpi-v green" id="pf-kpi-repuesto">-</span><span class="kpi-s">devuelto</span></div>
    <div class="kpi"><span class="kpi-l">Diferencia</span><span class="kpi-v red" id="pf-kpi-dif">-</span><span class="kpi-s">pendiente de reponer</span></div>
  </div>

  <div class="card-box">
    <div class="card-head">
      <span class="card-head-title">Rendición Pago Fácil — usado vs repuesto</span>
      <button class="add-btn" onclick="addPF()">+ Agregar movimiento</button>
    </div>
    <div class="row-header g-pf">
      <div class="col-label">Concepto / Proveedor</div>
      <div class="col-label">Fecha uso</div>
      <div class="col-label" style="text-align:right">Usado ($)</div>
      <div class="col-label">Fecha reposición</div>
      <div class="col-label" style="text-align:right">Repuesto ($)</div>
      <div class="col-label" style="text-align:center">Estado</div>
      <div></div>
    </div>
    <div id="pf-rows"></div>
  </div>
</div>

<!-- ═══ PANEL RESUMEN MES ═══════════════════════════════════════════════════ -->
<div class="panel" id="panel-resumen">
  <div id="resumen-content"></div>
</div>

<script>
// ── STORAGE ──────────────────────────────────────────────────────────────────
const KEY = 'ganem_contab_v2';
let db = {
  proveedores: [],
  gastos: [],
  recaudacion: [],
  rendicionPF: [],
  semProv:1, semGasto:1, semRecaud:1
};

function guardar(){
  localStorage.setItem(KEY, JSON.stringify(db));
  const ind = document.getElementById('save-indicator');
  ind.classList.add('show');
  setTimeout(()=>ind.classList.remove('show'),2000);
}
function cargar(){
  const raw = localStorage.getItem(KEY);
  if(raw){ try{ db = JSON.parse(raw); }catch(e){} }
  if(!db.proveedores) db.proveedores=[];
  if(!db.gastos) db.gastos=[];
  if(!db.recaudacion) db.recaudacion=[];
  if(!db.rendicionPF) db.rendicionPF=[];
  // Cargar datos iniciales si está vacío
  if(db.proveedores.length===0) cargarDatosIniciales();
}
function cargarDatosIniciales(){
  db.proveedores = [
    {id:uid(),sem:1,nombre:"GANEM",           fecha:"Lun 16 → reponer Miérc 18",monto:247258.85,pagado:0,   medio:"Pago Fácil",   estado:"PENDIENTE"},
    {id:uid(),sem:1,nombre:"VERDULERIA AGUILAR",fecha:"Lun 16 → reponer Miérc 18",monto:54474.93,pagado:0,  medio:"Pago Fácil",   estado:"PENDIENTE"},
    {id:uid(),sem:1,nombre:"FIAMBRE CERES",   fecha:"Vie 21 · Pago Fácil",      monto:81898.80, pagado:0,   medio:"Pago Fácil",   estado:"PENDIENTE"},
    {id:uid(),sem:1,nombre:"DUPUY",           fecha:"Vie 21 · Pago Fácil",      monto:82509,    pagado:0,   medio:"Pago Fácil",   estado:"PENDIENTE"},
    {id:uid(),sem:1,nombre:"RICHI",           fecha:"Después del 27",           monto:60000,    pagado:0,   medio:"A definir",    estado:"SIN FECHA"},
    {id:uid(),sem:1,nombre:"AGUSTINA · IBC",  fecha:"Esta semana si se puede",  monto:100000,   pagado:0,   medio:"Pago Fácil",   estado:"SIN FECHA"},
    {id:uid(),sem:1,nombre:"HOSICO",          fecha:"Vie 13 · pagado",          monto:40000,    pagado:40000,medio:"Pago Fácil",  estado:"PAGADO"},
    {id:uid(),sem:1,nombre:"ICBC Visa",       fecha:"Urgente · venció 10/03",   monto:48034.43, pagado:0,   medio:"Efectivo",     estado:"VENCIDO"},
  ];
  db.gastos = [
    {id:uid(),sem:1,concepto:"LUZ - Factura 1", fecha:"Lun 16",monto:0,     pagado:0,medio:"Efectivo → Banco",estado:"PENDIENTE"},
    {id:uid(),sem:1,concepto:"LUZ - Factura 2", fecha:"Lun 16",monto:0,     pagado:0,medio:"Efectivo → Banco",estado:"PENDIENTE"},
    {id:uid(),sem:1,concepto:"Otros gastos",    fecha:"Lun 16",monto:90000, pagado:0,medio:"Efectivo → Banco",estado:"PENDIENTE"},
  ];
  db.recaudacion = [
    {id:uid(),sem:1,dia:"Viernes 13/03",efectivo:167725,transferencia:12000},
    {id:uid(),sem:1,dia:"Sábado 14/03",efectivo:0,transferencia:0},
    {id:uid(),sem:1,dia:"Domingo 15/03",efectivo:0,transferencia:0},
  ];
  db.rendicionPF = [
    {id:uid(),concepto:"GANEM",         fechaUso:"16/03",usado:247258.85,fechaRep:"18/03",repuesto:0,   estado:"PENDIENTE"},
