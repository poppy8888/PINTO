<script>
const WSP = "543854102266";
let carrito = [];

function filtrar(cat, el) {
  document.querySelectorAll('.cat-pill').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  document.querySelectorAll('#grid .product-card').forEach(c => {
    c.classList.toggle('hidden', cat !== 'todos' && c.dataset.cat !== cat);
  });
}

function agregar(nombre, btn) {
  const i = carrito.findIndex(x => x.n === nombre);
  i >= 0 ? carrito[i].q++ : carrito.push({n: nombre, q: 1});
  btn.textContent = '✓ Listo!';
  btn.style.cssText = 'background:var(--dorado);border-color:var(--dorado);color:var(--negro)';
  setTimeout(() => { btn.textContent = '+ Agregar'; btn.style.cssText = ''; }, 1300);
  render();
  document.getElementById('cPanel').classList.add('open');
}

function cambiarQ(n, d) {
  const i = carrito.findIndex(x => x.n === n);
  if (i < 0) return;
  carrito[i].q += d;
  if (carrito[i].q <= 0) carrito.splice(i, 1);
  render();
}

function vaciar() { carrito = []; render(); }
function toggleC() { document.getElementById('cPanel').classList.toggle('open'); }

function render() {
  const el = document.getElementById('cItems');
  const cnt = document.getElementById('cCount');
  const btn = document.getElementById('cEnviar');
  if (!carrito.length) {
    el.innerHTML = '<p class="cp-empty">Tu carrito está vacío</p>';
    cnt.style.display = 'none';
    btn.style.pointerEvents = 'none'; btn.style.opacity = '.4';
    return;
  }
  let count = 0, html = '', msg = '🛒 *Pedido - Minimarket La Reina Pinto*\n\n';
  carrito.forEach(({n, q}) => {
    count += q;
    msg += `• ${n} x${q}\n`;
    const ns = n.replace(/'/g, "\\'");
    html += `<div class="cp-item"><div class="cp-iname">${n}</div><div class="cp-qctrl"><button class="cp-qbtn" onclick="cambiarQ('${ns}',-1)">−</button><span class="cp-qnum">${q}</span><button class="cp-qbtn" onclick="cambiarQ('${ns}',1)">+</button></div></div>`;
  });
  msg += '\nHola! Quiero hacer este pedido 😊';
  el.innerHTML = html;
  cnt.textContent = count; cnt.style.display = 'inline';
  btn.style.pointerEvents = 'auto'; btn.style.opacity = '1';
  btn.href = 'https://wa.me/' + WSP + '?text=' + encodeURIComponent(msg);
}
render();
</script>
